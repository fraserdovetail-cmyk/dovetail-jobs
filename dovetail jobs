<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Dovetail Jobs</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  *{box-sizing:border-box;margin:0;padding:0}
  :root{
    --green:#3B6D11;--green-light:#EAF3DE;--green-mid:#639922;--green-dark:#27500A;
    --charcoal:#1e1e1c;--surface:#f5f4f0;--white:#ffffff;
    --border:#e2e0d8;--border-strong:#c8c6bc;
    --text:#1e1e1c;--muted:#6b6a64;--hint:#9b9a94;
    --red:#A32D2D;--red-light:#FCEBEB;
    --amber:#854F0B;--amber-light:#FAEEDA;
    --blue:#185FA5;--blue-light:#E6F1FB;
    --radius:12px;--radius-sm:8px;
    --shadow:0 1px 3px rgba(0,0,0,0.06),0 4px 12px rgba(0,0,0,0.04);
  }
  html{font-family:'DM Sans',sans-serif;font-size:16px;color:var(--text);background:var(--surface)}
  body{min-height:100vh}

  /* ── LOGIN ── */
  #login-screen{display:flex;align-items:center;justify-content:center;min-height:100vh;padding:1.5rem;background:var(--surface)}
  .login-wrap{width:100%;max-width:380px}
  .login-brand{text-align:center;margin-bottom:2.5rem}
  .login-logo{display:inline-flex;align-items:center;gap:10px;margin-bottom:8px}
  .logo-mark{width:36px;height:36px;background:var(--green);border-radius:8px;display:flex;align-items:center;justify-content:center}
  .logo-mark svg{width:20px;height:20px;fill:none;stroke:#fff;stroke-width:2;stroke-linecap:round;stroke-linejoin:round}
  .brand-name{font-size:22px;font-weight:500;color:var(--charcoal);letter-spacing:-0.3px}
  .brand-sub{font-size:13px;color:var(--muted);margin-top:2px}
  .login-card{background:var(--white);border:1px solid var(--border);border-radius:var(--radius);padding:2rem;box-shadow:var(--shadow)}
  .login-card label{display:block;font-size:13px;color:var(--muted);margin-bottom:6px}
  .login-card input{width:100%;padding:11px 14px;border:1px solid var(--border);border-radius:var(--radius-sm);font-size:15px;font-family:'DM Sans',sans-serif;color:var(--text);background:var(--white);outline:none;transition:border-color 0.15s}
  .login-card input:focus{border-color:var(--green-mid)}
  .btn-login{width:100%;margin-top:14px;padding:12px;background:var(--green);color:#fff;border:none;border-radius:var(--radius-sm);font-size:15px;font-weight:500;font-family:'DM Sans',sans-serif;cursor:pointer;transition:background 0.15s}
  .btn-login:hover{background:var(--green-mid)}
  .login-error{font-size:13px;color:var(--red);text-align:center;margin-top:10px;min-height:20px}
  .login-hint{font-size:12px;color:var(--hint);text-align:center;margin-top:1.5rem}

  /* ── MAIN LAYOUT ── */
  #main-screen{display:none;flex-direction:column;min-height:100vh}
  .topbar{display:flex;align-items:center;justify-content:space-between;padding:0 20px;height:56px;background:var(--white);border-bottom:1px solid var(--border);position:sticky;top:0;z-index:20}
  .topbar-left{display:flex;align-items:center;gap:10px}
  .topbar-logo{width:28px;height:28px;background:var(--green);border-radius:6px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
  .topbar-logo svg{width:16px;height:16px;fill:none;stroke:#fff;stroke-width:2;stroke-linecap:round;stroke-linejoin:round}
  .topbar-name{font-size:15px;font-weight:500;color:var(--charcoal)}
  .topbar-right{display:flex;align-items:center;gap:8px}
  .sync-status{font-size:12px;color:var(--hint);display:flex;align-items:center;gap:5px}
  .sync-dot{width:7px;height:7px;border-radius:50%;background:var(--hint);flex-shrink:0;transition:background 0.3s}
  .sync-dot.synced{background:var(--green-mid)}
  .sync-dot.syncing{background:var(--amber);animation:pulse 1s infinite}
  .sync-dot.error{background:var(--red)}
  @keyframes pulse{0%,100%{opacity:1}50%{opacity:0.4}}

  .btn-new{display:flex;align-items:center;gap:6px;padding:7px 14px;background:var(--green);color:#fff;border:none;border-radius:var(--radius-sm);font-size:13px;font-weight:500;font-family:'DM Sans',sans-serif;cursor:pointer;transition:background 0.15s}
  .btn-new:hover{background:var(--green-mid)}
  .btn-outline{padding:7px 12px;background:transparent;color:var(--muted);border:1px solid var(--border);border-radius:var(--radius-sm);font-size:13px;font-family:'DM Sans',sans-serif;cursor:pointer;transition:all 0.15s}
  .btn-outline:hover{background:var(--surface);color:var(--text)}

  /* ── TABS ── */
  .tab-bar{display:flex;background:var(--white);border-bottom:1px solid var(--border);overflow-x:auto;-webkit-overflow-scrolling:touch;scrollbar-width:none}
  .tab-bar::-webkit-scrollbar{display:none}
  .tab{padding:12px 18px;font-size:13px;font-weight:400;color:var(--muted);cursor:pointer;white-space:nowrap;border-bottom:2px solid transparent;transition:all 0.15s;user-select:none}
  .tab:hover{color:var(--text)}
  .tab.active{color:var(--green);border-bottom-color:var(--green);font-weight:500}
  .tab-badge{display:inline-block;background:var(--surface);color:var(--hint);border-radius:10px;padding:1px 6px;font-size:11px;margin-left:4px;font-family:'DM Mono',monospace}
  .tab.active .tab-badge{background:var(--green-light);color:var(--green)}

  /* ── CONTENT AREA ── */
  .content{flex:1;padding:20px;max-width:900px;margin:0 auto;width:100%}

  /* ── FILTER BAR ── */
  .filter-bar{display:flex;gap:10px;margin-bottom:18px;flex-wrap:wrap}
  .search-wrap{flex:1;min-width:200px;position:relative}
  .search-icon{position:absolute;left:12px;top:50%;transform:translateY(-50%);width:15px;height:15px;color:var(--hint)}
  .search-input{width:100%;padding:9px 12px 9px 36px;border:1px solid var(--border);border-radius:var(--radius-sm);font-size:14px;font-family:'DM Sans',sans-serif;color:var(--text);background:var(--white);outline:none;transition:border-color 0.15s}
  .search-input:focus{border-color:var(--green-mid)}
  .filter-select{padding:9px 12px;border:1px solid var(--border);border-radius:var(--radius-sm);font-size:13px;font-family:'DM Sans',sans-serif;color:var(--text);background:var(--white);outline:none;cursor:pointer}

  /* ── JOB CARDS ── */
  .jobs-list{display:flex;flex-direction:column;gap:8px}
  .job-card{background:var(--white);border:1px solid var(--border);border-radius:var(--radius);padding:16px;cursor:pointer;transition:border-color 0.15s,box-shadow 0.15s}
  .job-card:hover{border-color:var(--border-strong);box-shadow:var(--shadow)}
  .job-card-top{display:flex;justify-content:space-between;align-items:flex-start;gap:12px}
  .job-card-meta{flex:1;min-width:0}
  .job-ref{font-size:11px;font-family:'DM Mono',monospace;color:var(--hint);margin-bottom:3px;letter-spacing:0.03em}
  .job-name{font-size:15px;font-weight:500;color:var(--charcoal);margin-bottom:2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
  .job-client{font-size:13px;color:var(--muted)}
  .stage-pill{font-size:11px;font-weight:500;padding:4px 10px;border-radius:20px;white-space:nowrap;flex-shrink:0}
  .job-footer{display:flex;gap:16px;margin-top:12px;padding-top:12px;border-top:1px solid var(--border);font-size:12px;color:var(--hint)}
  .job-footer span{display:flex;align-items:center;gap:4px}

  .s0{background:var(--blue-light);color:var(--blue)}
  .s1{background:#EAF3DE;color:#3B6D11}
  .s2{background:var(--amber-light);color:var(--amber)}
  .s3{background:#EAF3DE;color:#3B6D11}
  .s4{background:var(--amber-light);color:var(--amber)}
  .s5{background:#EAF3DE;color:#3B6D11}
  .s6{background:var(--blue-light);color:var(--blue)}
  .s7{background:var(--amber-light);color:var(--amber)}
  .s8{background:#EAF3DE;color:#3B6D11}
  .s9{background:#EAF3DE;color:var(--green-dark)}

  /* ── PIPELINE ── */
  .pipeline-scroll{overflow-x:auto;-webkit-overflow-scrolling:touch;padding-bottom:8px}
  .pipeline{display:flex;gap:12px;min-width:max-content;align-items:flex-start}
  .pipeline-col{width:200px;flex-shrink:0}
  .pipeline-col-hd{font-size:11px;font-weight:500;color:var(--muted);margin-bottom:8px;display:flex;align-items:center;justify-content:space-between}
  .pipeline-count{font-family:'DM Mono',monospace;font-size:11px;background:var(--surface);color:var(--hint);border-radius:8px;padding:1px 6px}
  .pipeline-cards{display:flex;flex-direction:column;gap:6px;min-height:50px}
  .pip-card{background:var(--white);border:1px solid var(--border);border-radius:var(--radius-sm);padding:10px 12px;cursor:pointer;transition:border-color 0.15s}
  .pip-card:hover{border-color:var(--border-strong)}
  .pip-name{font-size:13px;font-weight:500;color:var(--charcoal);margin-bottom:2px}
  .pip-client{font-size:12px;color:var(--muted)}
  .pip-val{font-size:12px;color:var(--green);font-weight:500;margin-top:4px;font-family:'DM Mono',monospace}
  .pip-empty{font-size:12px;color:var(--hint);padding:6px 0}

  /* ── STATS ── */
  .stats-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:10px;margin-bottom:24px}
  .stat-card{background:var(--white);border:1px solid var(--border);border-radius:var(--radius);padding:16px}
  .stat-label{font-size:12px;color:var(--muted);margin-bottom:8px}
  .stat-val{font-size:26px;font-weight:300;color:var(--charcoal);font-family:'DM Sans',sans-serif;letter-spacing:-0.5px}
  .stat-sub{font-size:12px;color:var(--hint);margin-top:2px}
  .stage-bar-row{display:flex;align-items:center;gap:10px;margin-bottom:9px}
  .stage-bar-label{font-size:12px;color:var(--muted);width:170px;flex-shrink:0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
  .stage-bar-track{flex:1;height:5px;background:var(--surface);border-radius:3px;overflow:hidden}
  .stage-bar-fill{height:100%;background:var(--green-mid);border-radius:3px;transition:width 0.4s}
  .stage-bar-count{font-size:12px;color:var(--text);font-family:'DM Mono',monospace;width:20px;text-align:right}

  /* ── EMPTY STATE ── */
  .empty{text-align:center;padding:4rem 1rem;color:var(--muted)}
  .empty-title{font-size:16px;font-weight:500;color:var(--text);margin-bottom:8px}

  /* ── MODAL ── */
  .modal-bg{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.35);z-index:100;overflow-y:auto;padding:20px 16px;backdrop-filter:blur(2px)}
  .modal-bg.open{display:flex;align-items:flex-start;justify-content:center}
  .modal{background:var(--white);border-radius:var(--radius);width:100%;max-width:580px;overflow:hidden;box-shadow:0 8px 32px rgba(0,0,0,0.12)}
  .modal-hd{display:flex;align-items:center;justify-content:space-between;padding:16px 20px;border-bottom:1px solid var(--border)}
  .modal-title{font-size:15px;font-weight:500;color:var(--charcoal)}
  .modal-close{background:none;border:none;font-size:22px;color:var(--hint);cursor:pointer;line-height:1;padding:0 2px;transition:color 0.15s}
  .modal-close:hover{color:var(--text)}
  .modal-body{padding:20px;max-height:70vh;overflow-y:auto}
  .modal-section{margin-bottom:22px}
  .modal-section:last-child{margin-bottom:0}
  .section-title{font-size:11px;font-weight:500;color:var(--hint);text-transform:uppercase;letter-spacing:0.07em;margin-bottom:12px}
  .form-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:12px}
  .form-grid.full{grid-template-columns:1fr}
  .form-group{display:flex;flex-direction:column;gap:5px}
  .form-label{font-size:12px;color:var(--muted)}
  .form-input{padding:9px 11px;border:1px solid var(--border);border-radius:var(--radius-sm);font-size:14px;font-family:'DM Sans',sans-serif;color:var(--text);background:var(--white);outline:none;transition:border-color 0.15s}
  .form-input:focus{border-color:var(--green-mid)}
  .form-input[readonly]{background:var(--surface);color:var(--hint);cursor:default}
  textarea.form-input{resize:vertical;min-height:70px;line-height:1.5}

  /* ── STAGE STEPPER ── */
  .stepper{display:flex;flex-direction:column;gap:5px}
  .step{display:flex;align-items:center;gap:12px;padding:9px 12px;border:1px solid var(--border);border-radius:var(--radius-sm);cursor:pointer;transition:all 0.15s;user-select:none}
  .step:hover:not(.step-done):not(.step-current){background:var(--surface)}
  .step-current{border-color:var(--green-mid);background:var(--green-light)}
  .step-done{background:var(--surface);border-color:var(--border)}
  .step-num{width:24px;height:24px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:500;flex-shrink:0;border:1px solid var(--border);color:var(--hint);background:var(--white);font-family:'DM Mono',monospace;transition:all 0.15s}
  .step-done .step-num,.step-current .step-num{background:var(--green);color:#fff;border-color:var(--green)}
  .step-label{font-size:13px;color:var(--text)}
  .step-done .step-label{color:var(--muted)}

  /* ── MODAL FOOTER ── */
  .modal-ft{display:flex;justify-content:space-between;align-items:center;padding:14px 20px;border-top:1px solid var(--border)}
  .modal-ft-right{display:flex;gap:8px}
  .btn-del{padding:8px 14px;background:transparent;color:var(--red);border:1px solid #f0c0c0;border-radius:var(--radius-sm);font-size:13px;font-family:'DM Sans',sans-serif;cursor:pointer;transition:all 0.15s}
  .btn-del:hover{background:var(--red-light)}
  .btn-cancel{padding:8px 14px;background:transparent;color:var(--muted);border:1px solid var(--border);border-radius:var(--radius-sm);font-size:13px;font-family:'DM Sans',sans-serif;cursor:pointer;transition:all 0.15s}
  .btn-cancel:hover{background:var(--surface)}
  .btn-save{padding:8px 18px;background:var(--green);color:#fff;border:none;border-radius:var(--radius-sm);font-size:13px;font-weight:500;font-family:'DM Sans',sans-serif;cursor:pointer;transition:background 0.15s;display:flex;align-items:center;gap:6px}
  .btn-save:hover{background:var(--green-mid)}
  .btn-save:disabled{opacity:0.5;cursor:not-allowed}

  /* ── TOAST ── */
  .toast{position:fixed;bottom:24px;left:50%;transform:translateX(-50%) translateY(80px);background:var(--charcoal);color:#fff;font-size:13px;padding:10px 18px;border-radius:20px;z-index:999;transition:transform 0.3s;white-space:nowrap;pointer-events:none}
  .toast.show{transform:translateX(-50%) translateY(0)}

  /* ── LOADING ── */
  .loading-screen{display:flex;align-items:center;justify-content:center;gap:10px;padding:3rem;color:var(--muted);font-size:14px}
  .spinner{width:18px;height:18px;border:2px solid var(--border);border-top-color:var(--green-mid);border-radius:50%;animation:spin 0.7s linear infinite;flex-shrink:0}
  @keyframes spin{to{transform:rotate(360deg)}}

  @media(max-width:520px){
    .form-grid{grid-template-columns:1fr}
    .topbar-name{display:none}
    .content{padding:14px}
    .sync-status span:last-child{display:none}
  }
</style>
</head>
<body>

<!-- LOGIN -->
<div id="login-screen">
  <div class="login-wrap">
    <div class="login-brand">
      <div class="login-logo">
        <div class="logo-mark">
          <svg viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        </div>
        <span class="brand-name">Dovetail Jobs</span>
      </div>
      <div class="brand-sub">Job tracking · Dovetail Carpentry & Building</div>
    </div>
    <div class="login-card">
      <label for="pwd">Access code</label>
      <input type="password" id="pwd" placeholder="Enter access code" autocomplete="current-password" />
      <button class="btn-login" onclick="doLogin()">Continue</button>
      <div class="login-error" id="login-err"></div>
    </div>
    <p class="login-hint">Share this page link + code with your team</p>
  </div>
</div>

<!-- MAIN -->
<div id="main-screen">
  <div class="topbar">
    <div class="topbar-left">
      <div class="topbar-logo">
        <svg viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
      </div>
      <span class="topbar-name">Dovetail Jobs</span>
    </div>
    <div class="topbar-right">
      <div class="sync-status">
        <div class="sync-dot" id="sync-dot"></div>
        <span id="sync-label">Loading</span>
      </div>
      <button class="btn-new" onclick="openNew()">
        <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="6.5" y1="1" x2="6.5" y2="12"/><line x1="1" y1="6.5" x2="12" y2="6.5"/></svg>
        New job
      </button>
      <button class="btn-outline" onclick="logout()">Sign out</button>
    </div>
  </div>
  <div class="tab-bar">
    <div class="tab active" onclick="switchTab('jobs',this)">Jobs <span class="tab-badge" id="tb-jobs">0</span></div>
    <div class="tab" onclick="switchTab('pipeline',this)">Pipeline</div>
    <div class="tab" onclick="switchTab('stats',this)">Overview</div>
  </div>

  <!-- JOBS -->
  <div class="content" id="tab-jobs">
    <div class="filter-bar">
      <div class="search-wrap">
        <svg class="search-icon" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="8.5" cy="8.5" r="5.5"/><line x1="13" y1="13" x2="18" y2="18"/></svg>
        <input type="text" class="search-input" id="search" placeholder="Search jobs, clients..." oninput="renderJobs()">
      </div>
      <select class="filter-select" id="stage-filter" onchange="renderJobs()">
        <option value="">All stages</option>
      </select>
    </div>
    <div class="jobs-list" id="jobs-list"></div>
  </div>

  <!-- PIPELINE -->
  <div class="content" id="tab-pipeline" style="display:none;padding-left:0;padding-right:0;max-width:100%">
    <div class="pipeline-scroll" style="padding:0 20px 20px">
      <div class="pipeline" id="pipeline"></div>
    </div>
  </div>

  <!-- STATS -->
  <div class="content" id="tab-stats" style="display:none">
    <div class="stats-grid" id="stats-grid"></div>
    <div class="section-title" style="margin-bottom:12px">Jobs by stage</div>
    <div id="stage-bars"></div>
  </div>
</div>

<!-- MODAL -->
<div class="modal-bg" id="modal" onclick="bgClick(event)">
  <div class="modal" id="modal-inner">
    <div class="modal-hd">
      <span class="modal-title" id="modal-title">New job</span>
      <button class="modal-close" onclick="closeModal()">×</button>
    </div>
    <div class="modal-body" id="modal-body"></div>
    <div class="modal-ft" id="modal-ft"></div>
  </div>
</div>

<!-- TOAST -->
<div class="toast" id="toast"></div>

<script>
const API = 'https://script.google.com/macros/s/AKfycbyw1VCKKJ3sFE53P4gfoLKgvTw_d4RK0tXXQvnRZQYPn_Wisb5-qnH9CsmtB49KP9zT/exec';
const PASS = 'dovetail2025';
const STAGES = [
  'Initial contact','Viewed job','Quote submitted','Quote approved',
  'Deposit issued','Deposit paid','Start date approved',
  'Work commenced','Work completed','Invoice issued'
];

let jobs = [];
let currentStage = 0;
let saving = false;

// ── AUTH ──
function doLogin() {
  const v = document.getElementById('pwd').value;
  if (v === PASS) {
    sessionStorage.setItem('dtv_auth','1');
    document.getElementById('login-screen').style.display = 'none';
    document.getElementById('main-screen').style.display = 'flex';
    init();
  } else {
    document.getElementById('login-err').textContent = 'Incorrect access code';
    document.getElementById('pwd').value = '';
  }
}
document.getElementById('pwd').addEventListener('keydown', e => { if(e.key==='Enter') doLogin(); });

function logout() {
  sessionStorage.removeItem('dtv_auth');
  document.getElementById('main-screen').style.display = 'none';
  document.getElementById('login-screen').style.display = 'flex';
}

if (sessionStorage.getItem('dtv_auth') === '1') {
  document.getElementById('login-screen').style.display = 'none';
  document.getElementById('main-screen').style.display = 'flex';
  init();
}

// ── INIT ──
function init() {
  populateStageFilter();
  loadJobs();
}

function setSyncStatus(state, label) {
  const dot = document.getElementById('sync-dot');
  dot.className = 'sync-dot ' + state;
  document.getElementById('sync-label').textContent = label;
}

// ── API ──
async function apiCall(body) {
  const res = await fetch(API, {
    method: 'POST',
    body: JSON.stringify(body)
  });
  return res.json();
}

async function loadJobs() {
  setSyncStatus('syncing', 'Loading...');
  document.getElementById('jobs-list').innerHTML = '<div class="loading-screen"><div class="spinner"></div> Loading jobs...</div>';
  try {
    const data = await apiCall({ action: 'getJobs' });
    jobs = (data.jobs || []).map(j => ({ ...j, stage: parseInt(j.stage) || 0 }));
    setSyncStatus('synced', 'Synced');
    renderAll();
  } catch(e) {
    setSyncStatus('error', 'Offline');
    document.getElementById('jobs-list').innerHTML = '<div class="empty"><div class="empty-title">Could not connect</div><p>Check your connection and refresh</p></div>';
  }
}

async function saveJobToSheet(job) {
  setSyncStatus('syncing', 'Saving...');
  try {
    await apiCall({ action: 'saveJob', job });
    setSyncStatus('synced', 'Saved');
    showToast('Job saved');
  } catch(e) {
    setSyncStatus('error', 'Save failed');
    showToast('Save failed — check connection');
  }
}

async function deleteJobFromSheet(id) {
  setSyncStatus('syncing', 'Deleting...');
  try {
    await apiCall({ action: 'deleteJob', id });
    setSyncStatus('synced', 'Synced');
    showToast('Job deleted');
  } catch(e) {
    setSyncStatus('error', 'Error');
    showToast('Delete failed');
  }
}

// ── RENDER ──
function renderAll() {
  renderJobs();
  renderPipeline();
  renderStats();
  document.getElementById('tb-jobs').textContent = jobs.length;
}

function populateStageFilter() {
  const s = document.getElementById('stage-filter');
  STAGES.forEach((st, i) => {
    const o = document.createElement('option');
    o.value = i; o.textContent = st; s.appendChild(o);
  });
}

function renderJobs() {
  const q = (document.getElementById('search').value || '').toLowerCase();
  const sf = document.getElementById('stage-filter').value;
  let list = jobs.filter(j => {
    const ms = sf === '' || j.stage == sf;
    const mq = !q || [j.name,j.client,j.ref,j.address].some(f => (f||'').toLowerCase().includes(q));
    return ms && mq;
  }).sort((a,b) => (b.updated||0) - (a.updated||0));

  const el = document.getElementById('jobs-list');
  if (!list.length) {
    el.innerHTML = `<div class="empty"><div class="empty-title">${jobs.length ? 'No matching jobs' : 'No jobs yet'}</div><p>${jobs.length ? 'Try adjusting your search' : 'Click "New job" to add your first'}</p></div>`;
    return;
  }
  el.innerHTML = list.map(j => `
    <div class="job-card" onclick="openJob('${j.id}')">
      <div class="job-card-top">
        <div class="job-card-meta">
          <div class="job-ref">${j.ref || ''}</div>
          <div class="job-name">${j.name || 'Untitled job'}</div>
          <div class="job-client">${j.client || '—'}</div>
        </div>
        <span class="stage-pill s${j.stage}">${STAGES[j.stage]}</span>
      </div>
      <div class="job-footer">
        ${j.value ? `<span>£${Number(j.value).toLocaleString()}</span>` : ''}
        ${j.address ? `<span>${j.address.split(',')[0]}</span>` : ''}
        ${j.startDate ? `<span>Start: ${j.startDate}</span>` : ''}
      </div>
    </div>`).join('');
}

function renderPipeline() {
  document.getElementById('pipeline').innerHTML = STAGES.map((s, i) => {
    const cols = jobs.filter(j => j.stage === i);
    return `<div class="pipeline-col">
      <div class="pipeline-col-hd">${s}<span class="pipeline-count">${cols.length}</span></div>
      <div class="pipeline-cards">${cols.length
        ? cols.map(j => `<div class="pip-card" onclick="openJob('${j.id}')">
            <div class="pip-name">${j.name || 'Untitled'}</div>
            <div class="pip-client">${j.client || '—'}</div>
            ${j.value ? `<div class="pip-val">£${Number(j.value).toLocaleString()}</div>` : ''}
          </div>`).join('')
        : `<div class="pip-empty">—</div>`}
      </div>
    </div>`;
  }).join('');
}

function renderStats() {
  const total = jobs.length;
  const active = jobs.filter(j => j.stage > 0 && j.stage < 9).length;
  const complete = jobs.filter(j => j.stage === 9).length;
  const totalVal = jobs.reduce((a, j) => a + (Number(j.value) || 0), 0);
  document.getElementById('stats-grid').innerHTML = `
    <div class="stat-card"><div class="stat-label">Total jobs</div><div class="stat-val">${total}</div></div>
    <div class="stat-card"><div class="stat-label">Active</div><div class="stat-val">${active}</div></div>
    <div class="stat-card"><div class="stat-label">Completed</div><div class="stat-val">${complete}</div></div>
    <div class="stat-card"><div class="stat-label">Total value</div><div class="stat-val">£${totalVal.toLocaleString()}</div><div class="stat-sub">across all jobs</div></div>`;
  document.getElementById('stage-bars').innerHTML = STAGES.map((s, i) => {
    const c = jobs.filter(j => j.stage === i).length;
    const pct = total ? Math.round(c / total * 100) : 0;
    return `<div class="stage-bar-row">
      <div class="stage-bar-label">${s}</div>
      <div class="stage-bar-track"><div class="stage-bar-fill" style="width:${pct}%"></div></div>
      <div class="stage-bar-count">${c}</div>
    </div>`;
  }).join('');
}

// ── MODAL ──
function genId() { return Date.now().toString(36) + Math.random().toString(36).slice(2,6); }
function genRef() { return 'DCB-' + String(jobs.length + 1).padStart(3,'0'); }

function openNew() {
  openJob(null);
}

function openJob(id) {
  const j = id ? jobs.find(x => x.id === id) : null;
  const isNew = !j;
  const d = j || { id: genId(), ref: genRef(), name:'', client:'', phone:'', email:'', address:'', value:'', startDate:'', notes:'', stage:0, created:Date.now(), updated:Date.now() };
  currentStage = d.stage;

  document.getElementById('modal-title').textContent = isNew ? 'New job' : (d.ref + (d.name ? ' — ' + d.name : ''));
  document.getElementById('modal-body').innerHTML = `
    <div class="modal-section">
      <div class="section-title">Job details</div>
      <div class="form-grid">
        <div class="form-group"><label class="form-label">Reference</label><input class="form-input" id="f-ref" value="${d.ref||''}" readonly /></div>
        <div class="form-group"><label class="form-label">Job description</label><input class="form-input" id="f-name" value="${esc(d.name||'')}" placeholder="e.g. Kitchen extension" /></div>
      </div>
      <div class="form-grid">
        <div class="form-group"><label class="form-label">Value (£)</label><input class="form-input" id="f-value" type="number" value="${d.value||''}" placeholder="0" /></div>
        <div class="form-group"><label class="form-label">Target start date</label><input class="form-input" id="f-start" type="date" value="${d.startDate||''}" /></div>
      </div>
      <div class="form-grid full">
        <div class="form-group"><label class="form-label">Site address</label><input class="form-input" id="f-addr" value="${esc(d.address||'')}" placeholder="e.g. 12 High Street, Stamford" /></div>
      </div>
      <div class="form-grid full">
        <div class="form-group"><label class="form-label">Notes</label><textarea class="form-input" id="f-notes">${esc(d.notes||'')}</textarea></div>
      </div>
    </div>
    <div class="modal-section">
      <div class="section-title">Client</div>
      <div class="form-grid">
        <div class="form-group"><label class="form-label">Name</label><input class="form-input" id="f-client" value="${esc(d.client||'')}" placeholder="Full name or company" /></div>
        <div class="form-group"><label class="form-label">Phone</label><input class="form-input" id="f-phone" value="${esc(d.phone||'')}" placeholder="07..." /></div>
      </div>
      <div class="form-grid full">
        <div class="form-group"><label class="form-label">Email</label><input class="form-input" id="f-email" type="email" value="${esc(d.email||'')}" placeholder="client@email.com" /></div>
      </div>
    </div>
    <div class="modal-section">
      <div class="section-title">Workflow stage</div>
      <div class="stepper" id="stepper">${buildStepper(currentStage)}</div>
    </div>`;

  document.getElementById('modal-ft').innerHTML = `
    <div>${!isNew ? `<button class="btn-del" onclick="deleteJob('${d.id}')">Delete job</button>` : '<span></span>'}</div>
    <div class="modal-ft-right">
      <button class="btn-cancel" onclick="closeModal()">Cancel</button>
      <button class="btn-save" id="save-btn" onclick="saveJob('${d.id}','${isNew}')">Save job</button>
    </div>`;

  document.getElementById('modal').classList.add('open');
}

function buildStepper(current) {
  return STAGES.map((s, i) => `
    <div class="step ${i < current ? 'step-done' : i === current ? 'step-current' : ''}" onclick="setStage(${i})" id="step-${i}">
      <div class="step-num">${i < current ? '✓' : i + 1}</div>
      <div class="step-label">${s}</div>
    </div>`).join('');
}

function setStage(i) {
  currentStage = i;
  document.getElementById('stepper').innerHTML = buildStepper(i);
}

function esc(s) { return String(s).replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/</g,'&lt;'); }

async function saveJob(id, isNew) {
  if (saving) return;
  saving = true;
  const btn = document.getElementById('save-btn');
  btn.disabled = true;
  btn.textContent = 'Saving...';

  const existing = jobs.find(x => x.id === id) || {};
  const job = {
    id,
    ref: document.getElementById('f-ref').value,
    name: document.getElementById('f-name').value,
    client: document.getElementById('f-client').value,
    phone: document.getElementById('f-phone').value,
    email: document.getElementById('f-email').value,
    address: document.getElementById('f-addr').value,
    value: document.getElementById('f-value').value,
    startDate: document.getElementById('f-start').value,
    notes: document.getElementById('f-notes').value,
    stage: currentStage,
    created: isNew === 'true' ? Date.now() : (existing.created || Date.now()),
    updated: Date.now()
  };

  const idx = jobs.findIndex(x => x.id === id);
  if (idx >= 0) jobs[idx] = job; else jobs.push(job);

  closeModal();
  renderAll();
  await saveJobToSheet(job);
  saving = false;
}

async function deleteJob(id) {
  if (!confirm('Delete this job? This cannot be undone.')) return;
  jobs = jobs.filter(x => x.id !== id);
  closeModal();
  renderAll();
  await deleteJobFromSheet(id);
}

function closeModal() { document.getElementById('modal').classList.remove('open'); }
function bgClick(e) { if (e.target === document.getElementById('modal')) closeModal(); }

// ── TABS ──
function switchTab(name, el) {
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  el.classList.add('active');
  ['jobs','pipeline','stats'].forEach(t => {
    document.getElementById('tab-'+t).style.display = t === name ? '' : 'none';
  });
  if (name === 'pipeline') renderPipeline();
  if (name === 'stats') renderStats();
}

// ── TOAST ──
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2500);
}
</script>
</body>
</html>
